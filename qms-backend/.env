APP_NAME="QMS Pro"
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=Asia/Riyadh
APP_URL=http://localhost/qms-pro/qms-backend/public

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=qms_db
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=480

SANCTUM_STATEFUL_DOMAINS=localhost:4200,127.0.0.1:4200
